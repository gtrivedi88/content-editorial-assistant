LOG_LEVEL=DEBUG
ENVIRONMENT=local
API_TIMEOUT=30
MAX_CONCURRENT_REQUESTS=10
CACHE_TTL=300
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=300

PLATFORM=lightrail

# Model configuration
MODEL_PROVIDER=llamastack
LLAMASTACK_MODEL=style_analyzer_model
MODEL_MAX_TOKENS=4096
MODEL_TEMPERATURE=0.7

# Database configuration (non-sensitive)
DB_POOL_SIZE=5
DB_TIMEOUT=30

# Feature flags
ENABLE_ANALYTICS=false
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

CEA_MODEL_BASE_URL=http://host.containers.internal:5111/v1
CEA_MODEL_ID=TinyLlama/TinyLlama-1.1B-Chat-v1.0
