LOG_LEVEL=DEBUG
ENVIRONMENT=local
API_TIMEOUT=30
MAX_CONCURRENT_REQUESTS=10
CACHE_TTL=300
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=300

PLATFORM=lightrail

# Model configuration — Google Gemini via OpenAI-compatible API
MODEL_PROVIDER=api
BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
MODEL_ID=gemini-2.0-flash-lite
MODEL_MAX_TOKENS=16384
MODEL_ANALYSIS_TEMPERATURE=0.0
MODEL_SEED=42
LLM_ENABLED=True

# Database configuration (non-sensitive)
DB_POOL_SIZE=5
DB_TIMEOUT=30

# LanguageTool grammar checker
LANGUAGETOOL_ENABLED=true
LANGUAGETOOL_URL=http://localhost:8010
LANGUAGETOOL_TIMEOUT=8
LANGUAGETOOL_LEVEL=picky
LANGUAGETOOL_FILTER_HINTS=true

# Feature flags
ENABLE_ANALYTICS=false
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Documentation
DOCS_URL=https://ccs-ai.pages.gitlab.cee.redhat.com/content-editorial-assistant/
