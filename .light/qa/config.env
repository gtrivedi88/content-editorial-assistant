# QA environment configuration variables
LOG_LEVEL=INFO
ENVIRONMENT=qa
PLATFORM=lightrail

# Model configuration
MODEL_PROVIDER=llamastack
CEA_MODEL_ID=gemini-2.5-flash
CEA_MODEL_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
REQUESTS_CA_BUNDLE=/etc/ssl/cert.pem
SSL_CERT_FILE=/etc/ssl/cert.pem

# Database configuration
DATABASE_HOST=pg-shared-13-stage-aurora-cluster.cluster-cgsqlp5mf68r.us-east-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=ccs_ai_data
DATABASE_USER=ccs_ai_cea_user
DATABASE_SCHEMA=cea
DATABASE_SSLMODE=require

# Model generation parameters
MODEL_ANALYSIS_TEMPERATURE=0.0
MODEL_SEED=42
MODEL_MAX_TOKENS=16384
MODEL_TOP_P=0.7
MODEL_TOP_K=20

# Application settings
TIMEOUT=30
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=300

# LanguageTool grammar checker (same namespace service)
LANGUAGETOOL_ENABLED=true
LANGUAGETOOL_URL=http://languagetool:8010
LANGUAGETOOL_TIMEOUT=8
LANGUAGETOOL_LEVEL=picky
LANGUAGETOOL_FILTER_HINTS=true

# Documentation
DOCS_URL=https://ccs-ai.pages.gitlab.cee.redhat.com/content-editorial-assistant/

# LLM health cache TTL (seconds) — reduces probe-induced /v1/models calls
LLM_CACHE_TTL=120

# Performance tuning (defaults from config.py — uncomment to override)
# LLM_CHUNK_SIZE=3500
# LLM_CHUNK_OVERLAP=2
# LLM_GLOBAL_MIN_WORDS=300
# LLM_JUDGE_BATCH_SIZE=25

# Performance monitoring
ENABLE_PERFORMANCE_MONITORING=true
