# Prod environment configuration variables
LOG_LEVEL=DEBUG
ENVIRONMENT=prod
PLATFORM=lightrail

# Model configuration
MODEL_PROVIDER=llamastack
CEA_MODEL_ID=models/gemini-3-flash-preview
CEA_MODEL_BASE_URL=https://gemini--apicast-production.apps.int.stc.ai.prod.us-east-1.aws.paas.redhat.com:443/v1beta/openai
REQUESTS_CA_BUNDLE=/etc/ssl/cert.pem
SSL_CERT_FILE=/etc/ssl/cert.pem

# Database configuration
DATABASE_HOST=pg-shared-13-prod-aurora-cluster.cluster-cgsqlp5mf68r.us-east-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=ccs_ai_data
DATABASE_USER=ccs_ai_cea_user
DATABASE_SCHEMA=cea
DATABASE_SSLMODE=require

# Model generation parameters
MODEL_TEMPERATURE=0.4
MODEL_MAX_TOKENS=3072
MODEL_TOP_P=0.7
MODEL_TOP_K=20

# Application settings
TIMEOUT=30
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=300

# Performance monitoring
ENABLE_PERFORMANCE_MONITORING=true
