# ============================================================
# Content Editorial Assistant (CEA) — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# --- Flask ---
# Secret key for session signing. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Maximum upload size in bytes (default: 10485760 = 10 MB)
MAX_CONTENT_LENGTH=10485760
# Maximum text length in characters for direct text input (default: 50000)
MAX_TEXT_LENGTH=50000

# --- SpaCy ---
# SpaCy model name (default: en_core_web_md)
SPACY_MODEL=en_core_web_md

# --- LLM / Model Provider ---
# Enable or disable LLM-based analysis (default: True)
LLM_ENABLED=True
# Provider type: llamastack, api, or ollama (default: llamastack)
MODEL_PROVIDER=llamastack
# Model ID for the provider
CEA_MODEL_ID=style_analyzer_model
# Model generation parameters
MODEL_ANALYSIS_TEMPERATURE=0.0
MODEL_SEED=42
MODEL_MAX_TOKENS=3072
MODEL_TOP_P=0.7
MODEL_TOP_K=20
# Max concurrent LLM requests (default: 5)
LLM_MAX_CONCURRENT=5
# Max document word count for LLM global pass (default: 5000)
LLM_GLOBAL_PASS_MAX_WORDS=5000
# Max tokens for style guide excerpts sent to LLM (default: 8000)
LLM_EXCERPT_BUDGET_MAX=8000

# --- Provider-specific (set based on MODEL_PROVIDER) ---
# For 'api' provider:
# BASE_URL=https://api.example.com/v1
# MODEL_ID=model-name
# ACCESS_TOKEN=your-token
# CERT_PATH=/path/to/cert.pem

# For 'llamastack' provider (set by LightRail platform):
# LIGHTRAIL_LLAMA_STACK_BASE_URL=...
# CEA_MODEL_BASE_URL=...
# CEA_MODEL_API_TOKEN=...

# For 'ollama' provider:
# BASE_URL=http://localhost:11434
# MODEL_ID=llama3:8b

# --- Analysis ---
# Minimum confidence score to surface an issue (default: 0.7)
CONFIDENCE_THRESHOLD=0.7

# --- Feedback ---
# Path to SQLite feedback database (default: data/feedback.db)
FEEDBACK_DB_PATH=data/feedback.db
# Enable persistent feedback storage; False uses in-memory SQLite (default: True)
FEEDBACK_PERSISTENT=True

# --- Sessions ---
# Session time-to-live in seconds (default: 3600)
SESSION_TTL_SECONDS=3600

# --- CORS ---
# Allowed CORS origins, comma-separated or '*' for all (default: *)
CORS_ORIGINS=*

# --- Proxy ---
# HTTPS proxy URL (default: None)
HTTPS_PROXY=
# HTTP proxy URL (default: None)
HTTP_PROXY=
# Comma-separated list of hosts to bypass proxy (default: None)
NO_PROXY=

# --- AsciiDoc ---
# Max concurrent Asciidoctor subprocesses (default: 3)
ASCIIDOCTOR_MAX_CONCURRENT=3

# --- PDF ---
# Percentage of page height to crop from top and bottom margins (default: 8)
PDF_MARGIN_CROP_PERCENT=8
